generator client {
  provider     = "prisma-client"
  output       = "./generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Board {
  id String @id @default(nanoid())

  title       String
  description String?

  languageFrom String   @map("language_from")
  languageTo   String   @map("language_to")
  isPublic     Boolean  @map("is_public")
  tags         String[]
  totalWords   Int      @default(0) @map("total_words")
  boardColor   String   @default("895AF6") @map("board_color")

  words     Word[]
  trainings Training[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("boards")
}

model Word {
  id String @id @default(nanoid())

  original  String
  //TODO: Create variations -> Tranlate String[var1, var2, var3]
  translate String

  correctCount Int @default(0) @map("correct_count")
  wrongCount   Int @default(0) @map("wrong_count")
  shownCount   Int @default(0) @map("shown_count")

  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("words")
}

model Training {
  id String @id @default(nanoid())

  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId String @map("board_id")

  correctAnswers   Int @default(0) @map("correct_answers")
  incorrectAnswers Int @default(0) @map("incorrect_answers")
  skippedAnswers   Int @default(0) @map("skipped_answers")

  currentIssue Int     @default(0) @map("current_issue")
  isFinished   Boolean @default(false) @map("is_finished")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("trainings")
}
